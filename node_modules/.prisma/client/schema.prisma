generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ApiKey {
  id        String   @id @default(uuid())
  key       String   @unique
  createdAt DateTime @default(now())
  active    Boolean  @default(true)
}

model License {
  id        String   @id @default(uuid())
  code      String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  expiresAt DateTime
}

model StudentEmail {
  id        String   @id @default(uuid())
  email     String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model CheckLog {
  id           String   @id @default(uuid())
  domain       String
  apiKey       String
  studentEmail String
  license      String
  status       String
  anomalyScore Float
  latencyAvg   Float
  createdAt    DateTime @default(now())
}
